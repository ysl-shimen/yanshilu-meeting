# 注释：项目通用忽略规则
# 1. 敏感配置文件
.env
.env.*
.local
./server/config/*.json

# 2. 前端项目依赖/构建目录
node_modules/
dist/
build/
*.js.map
pnpm-lock.yaml
package-lock.json

# 3. 后端/工具类文件
logs/
temp/
*.pyc
*.jar

# 4. 编辑器/IDE配置文件
.idea/
.vscode/
*.swp
*.swo

# 5. 大文件/缓存文件
*.zip
*.rar
.DS_Store  # Mac系统隐藏文件
Thumbs.db  # Windows系统隐藏文件

# 例外：保留 src/assets/avatar.png（即使忽略了*.png）
!src/assets/avatar.png